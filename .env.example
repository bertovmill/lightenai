# ── Database: Neon (Postgres) ──────────────────────────────
# Auto-provisioned by the Neon integration on the Vercel Marketplace.
# Pull locally with: vercel env pull .env.local
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Auth: Clerk ────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
# Comma-separated emails that get admin access (read on client + server)
NEXT_PUBLIC_ADMIN_EMAILS=bertmill19@gmail.com

# ── File storage: Vercel Blob ──────────────────────────────
# Auto-provisioned when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Anthropic (for Ray agent) ──────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Fal AI (for asset generation) ──────────────────────────
FAL_KEY=your_fal_api_key_here

# ── Resend (email notifications) ───────────────────────────
RESEND_API_KEY=re_your_api_key_here
NOTIFICATION_EMAIL=you@example.com

# ── Managed Agent — "AI Agency Content" blog writer (platform.claude.com) ──
MANAGED_BLOG_AGENT_ID=agent_01WTinkBU1yKwe5cX1oEmvcR
MANAGED_BLOG_ENVIRONMENT_ID=env_01EA9JW8H4CxRsE1PXK1QTr8
